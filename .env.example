# Copy to .env for local dev. In production, values come from Secret Manager / env vars set by Cloud Run.

GCP_PROJECT=your-gcp-project-id
BQ_LOCATION=asia-southeast1

# Supermetrics
SUPERMETRICS_API_KEY=paste-api-key-here
SUPERMETRICS_TEAM_ID=optional-team-id

# Dataset names (defaults shown)
RAW_DATASET=raw_supermetrics
STG_DATASET=stg
FACT_DATASET=fact
MART_DATASET=mart
SEED_DATASET=seeds

LOG_LEVEL=INFO

# For local dev only — point google-cloud libraries at a key file (NOT used in prod).
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/sa-key.json
