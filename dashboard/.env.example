# ─── Local dev (no GCP needed) ────────────────────────────────────────────
# Leave this on and the dashboard runs entirely against the deterministic
# in-memory mock panel (matches the seed=42 PRD-A narrative).
NEXT_PUBLIC_USE_MOCK=1

# ─── Live BigQuery (production / real demos) ──────────────────────────────
# Set NEXT_PUBLIC_USE_MOCK=0 and fill in the rest.
GCP_PROJECT=your-demo-project
BQ_LOCATION=asia-southeast1
MART_DATASET=mart

# ── Credentials — pick ONE ──
# Local disk path (works on your laptop, does NOT work on Vercel):
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/key.json
# Inline JSON (required on Vercel — paste the whole service-account JSON):
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ─── Optional password gate ───────────────────────────────────────────────
# If set, middleware requires ?code=<value> on first visit, then cookies it.
DEMO_ACCESS_CODE=
