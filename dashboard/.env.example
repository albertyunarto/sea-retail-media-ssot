# BigQuery backend. If BQ_* vars are absent, the dashboard falls back to
# the deterministic JS mock (matches the seed=42 simulation narrative).
GCP_PROJECT=your-demo-project
BQ_LOCATION=asia-southeast1

# Path to a service-account JSON key OR inline the JSON (one or the other).
# For Vercel deployments put the JSON in GOOGLE_APPLICATION_CREDENTIALS_JSON.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# Optional password gate (middleware checks DEMO_ACCESS_CODE).
DEMO_ACCESS_CODE=

# Force mock data regardless of BQ creds ("1" to enable).
NEXT_PUBLIC_USE_MOCK=1
